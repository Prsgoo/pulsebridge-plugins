{
  "name": "pulsebridge-plugins",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "generators": "./tools/generators/generators.json",
  "scripts": {
    "build": "nx run-many -t build --exclude=pulsebridge-plugins",
    "clean": "nx run-many -t clean --exclude=pulsebridge-plugins",
    "typecheck": "nx run-many -t typecheck --exclude=pulsebridge-plugins",
    "test": "nx run-many -t test --exclude=pulsebridge-plugins",
    "test:coverage": "nx run-many -t test:coverage --exclude=pulsebridge-plugins",
    "test:mutation": "stryker run",
    "validate": "npm run typecheck && npm run lint && npm run format:check",
    "publish:npm": "nx run-many -t publish:npm --exclude=pulsebridge-plugins --parallel=1",
    "publish:local": "nx run-many -t publish:local --exclude=pulsebridge-plugins",
    "publish:local:alpha": "nx run-many -t publish:local:alpha --exclude=pulsebridge-plugins",
    "affected:build": "nx affected -t build --exclude=pulsebridge-plugins",
    "affected:test": "nx affected -t test --exclude=pulsebridge-plugins",
    "generate:plugin": "nx g ./tools/generators/generators.json:plugin",
    "graph": "nx graph",
    "format": "prettier --write \"packages/**/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/**/src/**/*.ts\"",
    "lint": "eslint \"packages/**/src/**/*.ts\"",
    "lint:fix": "eslint \"packages/**/src/**/*.ts\" --fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@nx/devkit": "^22.7.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "nx": "^22.7.1",
    "prettier": "3.8.1",
    "pulsebridge": "^0.1.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  }
}
