{
  "name": "@prsgoo/processor-wildfire-feed",
  "version": "0.1.0-alpha.1",
  "description": "PulseBridge processor that aggregates wildfire.event records into a unified wildfire feed view.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Prsgoo/pulsebridge-plugins.git",
    "directory": "packages/processor-wildfire-feed"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "pulsebridge",
    "pulsebridge-plugin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "publish:npm": "npm publish",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "pulsebridge": "^0.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
