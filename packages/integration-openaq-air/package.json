{
  "name": "@prsgoo/integration-openaq-air",
  "version": "0.1.0",
  "description": "PulseBridge integration plugin for OpenAQ v3 air quality measurements.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Prsgoo/pulsebridge-plugins.git",
    "directory": "packages/integration-openaq-air"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "pulsebridge",
    "pulsebridge-plugin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "publish:npm": "npm publish",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "pulsebridge": "^0.1.0",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
