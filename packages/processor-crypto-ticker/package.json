{
  "name": "@prsgoo/processor-crypto-ticker",
  "version": "0.1.0",
  "description": "PulseBridge processor that turns crypto.price records into a live ticker view with price movement.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Prsgoo/pulsebridge-plugins.git",
    "directory": "packages/processor-crypto-ticker"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "pulsebridge",
    "pulsebridge-plugin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "publish:npm": "npm publish",
    "publish:local": "npm publish --registry http://localhost:4873",
    "publish:local:alpha": "npm publish --registry http://localhost:4873 --tag alpha",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "pulsebridge": "^0.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
