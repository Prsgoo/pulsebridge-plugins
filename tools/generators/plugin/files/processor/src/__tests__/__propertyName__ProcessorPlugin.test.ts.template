import { describe, it, expect, vi, beforeEach } from "vitest";
import {
  <%= className %>,
  VIEW_<%= constantName %>,
  RECORD_TYPE_INPUT,
} from "../<%= propertyName %>ProcessorPlugin.js";

const mockLogger = {
  debug: vi.fn(),
  info: vi.fn(),
  warn: vi.fn(),
  error: vi.fn(),
};

function makeContext() {
  return {
    logger: mockLogger,
    now: () => new Date("2024-01-15T12:00:00Z"),
    secrets: { get: () => undefined, has: () => false },
  };
}

function makeRecord(entityKey: string, data: unknown = {}) {
  return {
    type: RECORD_TYPE_INPUT,
    timestamp: "2024-01-15T12:00:00Z",
    source: "test-source",
    entityKey,
    data,
  };
}

describe("<%= className %>", () => {
  let plugin: <%= className %>;

  beforeEach(() => {
    plugin = new <%= className %>();
    vi.clearAllMocks();
  });

  it("should return null when there are no relevant records", async () => {
    const ctx = makeContext();
    const result = await plugin.process([], ctx as never);
    expect(result).toBeNull();
  });

  it("should produce a view when relevant records are present", async () => {
    const ctx = makeContext();
    const records = [makeRecord("entity-1"), makeRecord("entity-2")];
    const result = await plugin.process(records as never, ctx as never);

    expect(result).not.toBeNull();
    expect(result?.view).toBe(VIEW_<%= constantName %>);
    expect(result?.items).toHaveLength(1);
  });

  it("should ignore records of unrelated types", async () => {
    const ctx = makeContext();
    const records = [
      { ...makeRecord("e1"), type: "unrelated.type" },
    ];
    const result = await plugin.process(records as never, ctx as never);
    expect(result).toBeNull();
  });
});
